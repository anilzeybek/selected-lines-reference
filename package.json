{
  "name": "selected-lines-reference",
  "displayName": "Selected Lines Reference",
  "description": "Copy the active file path and selected line range in a compact text format.",
  "version": "0.0.2",
  "publisher": "anilzeybek",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/anilzeybek/selected-lines-reference.git"
  },
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "selectedLinesReference.copy",
        "title": "Copy Selected Lines Reference",
        "category": "Selected Lines Reference"
      }
    ],
    "keybindings": [
      {
        "command": "selectedLinesReference.copy",
        "key": "ctrl+shift+alt+c",
        "mac": "ctrl+shift+alt+cmd+c",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.2"
  }
}
